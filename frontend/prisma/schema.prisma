// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  email       String   @unique
  password    String
  role        String   @default("employee")
  permissions String   // JSON string of allowed modules
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  activities  ActivityLog[]
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  status    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Client {
  id                    Int      @id @default(autoincrement())
  name                  String
  company_name          String?
  email                 String?
  phone                 String?
  address               String?
  referral_source       String?
  total_project_amount  Float?   @default(0)
  amount_received       Float?   @default(0)
  payment_status        String?  @default("pending")
  created_at            DateTime @default(now())
}

model Lead {
  id             Int      @id @default(autoincrement())
  company_name   String
  founder_name   String?
  contact_number String?
  email          String?
  business_type  String?
  category       String?
  gst_number     String?
  assigned_to    Int?
  status         String?  @default("New")
  notes          String?
  created_at     DateTime @default(now())
}

model Bill {
  id              Int      @id @default(autoincrement())
  client_id       Int?
  client_name     String
  client_email    String?
  client_phone    String?
  client_address  String?
  bill_date       String?
  due_date        String?
  subtotal        Float    @default(0)
  tax_percent     Float    @default(18)
  tax_amount      Float    @default(0)
  total_amount    Float    @default(0)
  status          String   @default("Unpaid")
  notes           String?
  created_at      DateTime @default(now())
  
  items           BillItem[]
}

model BillItem {
  id          Int    @id @default(autoincrement())
  bill_id     Int
  description String
  quantity    Float
  unit_price  Float
  total       Float
  
  bill        Bill   @relation(fields: [bill_id], references: [id], onDelete: Cascade)
}

model Quotation {
  id              Int      @id @default(autoincrement())
  client_id       Int?
  client_name     String
  client_email    String?
  client_phone    String?
  client_address  String?
  quotation_date  String?
  subtotal        Float    @default(0)
  tax_percent     Float    @default(18)
  tax_amount      Float    @default(0)
  total_amount    Float    @default(0)
  notes           String?
  created_at      DateTime @default(now())
  
  items           QuotationItem[]
}

model QuotationItem {
  id            Int    @id @default(autoincrement())
  quotation_id  Int
  description   String
  quantity      Float
  unit_price    Float
  total         Float
  
  quotation     Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)
}

model Employee {
  id              Int      @id @default(autoincrement())
  profile_image   String?
  full_name       String
  designation     String
  employment_type String   @default("Full Time")
  college_name    String?
  email           String?
  phone           String?
  address         String?
  base_salary     Float
  joining_date    DateTime?
  bank_name       String?
  account_number  String?
  ifsc_code       String?
  pan_card        String?
  created_at      DateTime @default(now())
}
